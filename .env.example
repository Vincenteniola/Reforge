# Copy this file to .env.local and fill in your real keys.
# Never commit .env.local to GitHub — it holds secrets.

# --- Clerk (auth) ---
# Get these from clerk.com after creating an app
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx

# --- Supabase (database) ---
# Get these from supabase.com -> your project -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxx

# --- Resend (sending fatigue alert emails) ---
# Get this from resend.com -> API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# --- Meta Marketing API (reading ad account data) ---
# Get these from developers.facebook.com after creating an app
META_APP_ID=xxxxxxxxxxxx
META_APP_SECRET=xxxxxxxxxxxx

# --- Cron security ---
# A random password you make up yourself, so only Vercel's scheduler
# can trigger the fatigue-check job (not a random person on the internet).
CRON_SECRET=make-up-a-long-random-string-here
